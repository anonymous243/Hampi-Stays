// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

// ─────────────────────────────────────────────────────────────
// DATABASE CONNECTION
// Only the DATABASE_URL in .env needs to change when switching
// from local → Neon → Render. No code changes required.
// ─────────────────────────────────────────────────────────────
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  TRAVELLER
  RESORT_OWNER
  SUPER_ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
}

enum ResortStatus {
  DRAFT
  ACTIVE
  SUSPENDED
}

// ─────────────────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String?   // Optional for OAuth users
  role          Role      @default(TRAVELLER)
  avatar        String?   // Custom avatar
  image         String?   // NextAuth standard image field
  emailVerified DateTime? // NextAuth standard field
  phone         String?
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Auth.js relations
  accounts      Account[]
  sessions      Session[]

  // Application Relations
  bookings      Booking[] @relation("TravellerBookings")
  resorts       Resort[]  @relation("OwnerResorts")
  reviews       Review[]

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Resort {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  description     String
  shortDesc       String
  location        String
  address         String
  latitude        Float?
  longitude       Float?
  pricePerNight   Float
  maxGuests       Int          @default(2)
  images          String[]     // Array of image URLs
  amenities       String[]     // e.g. ["Pool", "Spa", "WiFi"]
  status          ResortStatus @default(DRAFT)
  isFeatured      Boolean      @default(false)
  commissionRate  Float        @default(7) // percentage (7 or 10)
  totalEarnings   Float        @default(0)
  rating          Float        @default(0)
  reviewCount     Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  ownerId         String
  owner           User         @relation("OwnerResorts", fields: [ownerId], references: [id])
  bookings        Booking[]
  reviews         Review[]
  availability    Availability[]

  @@map("resorts")
}

model Booking {
  id               String        @id @default(cuid())
  checkIn          DateTime
  checkOut         DateTime
  guests           Int
  nights           Int
  pricePerNight    Float
  subtotal         Float         // pricePerNight * nights
  commissionRate   Float         // snapshot of rate at booking time
  commissionAmount Float         // subtotal * commissionRate / 100
  ownerEarnings    Float         // subtotal - commissionAmount
  totalPrice       Float         // what traveller pays = subtotal (commission is owner's cut)
  status           BookingStatus @default(PENDING)
  specialRequests  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  travellerId      String
  traveller        User          @relation("TravellerBookings", fields: [travellerId], references: [id])
  resortId         String
  resort           Resort        @relation(fields: [resortId], references: [id])
  payment          Payment?
  review           Review?

  @@map("bookings")
}

model Payment {
  id              String        @id @default(cuid())
  razorpayOrderId String?       @unique
  razorpayPaymentId String?     @unique
  amount          Float
  currency        String        @default("INR")
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  bookingId       String        @unique
  booking         Booking       @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1-5
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  resortId  String
  resort    Resort   @relation(fields: [resortId], references: [id])
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])

  @@map("reviews")
}

model Availability {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  isBlocked Boolean  @default(false)
  reason    String?  // e.g. "Owner blocked", "Maintenance"
  createdAt DateTime @default(now())

  // Relations
  resortId  String
  resort    Resort   @relation(fields: [resortId], references: [id])

  @@unique([resortId, date])
  @@map("availability")
}
