# HampiStays — Environment Variables Template
# Copy this file to .env and fill in your values.
# .env is gitignored — this file is safe to commit.

# ─── DATABASE ──────────────────────────────────────────────
# Local PostgreSQL:
DATABASE_URL="postgresql://hampistays:hampistays123@localhost:5432/hampistays_db"

# Neon (swap here when going to production):
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/hampistays?sslmode=require"

# Render (alternative):
# DATABASE_URL="postgresql://user:pass@dpg-xxx.render.com/hampistays"

# ─── NEXTAUTH ──────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3001"

# ─── ADMIN ─────────────────────────────────────────────────
ADMIN_EMAIL="admin@hampistays.com"
ADMIN_PASSWORD_HASH=""

# ─── RAZORPAY (Phase 3) ────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# ─── COMMISSION ────────────────────────────────────────────
COMMISSION_STANDARD_PERCENT=7
COMMISSION_PEAK_PERCENT=10
